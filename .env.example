# GEMINI_API_KEY: Required for Gemini API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
APP_URL=
# RESEND_API_KEY: Required for email confirmations
RESEND_API_KEY=

# EXTERNAL_DEPLOYMENT_PORT: Used strictly for external deployments (GitHub -> Other Server) to bypass
# the AI Studio hardcoded requirement of PORT 3000. E.g., EXTERNAL_DEPLOYMENT_PORT=8080
EXTERNAL_DEPLOYMENT_PORT=8080
