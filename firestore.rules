rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Use exists() before get() to prevent evaluation errors if the user document is missing
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Restaurant Validation ---
    function isValidRestaurant(data) {
      // Use resilient checks that allow optional fields and ensure base types
      return data.get('name', '') is string && data.get('name', '').size() <= 100
        && data.get('ownerId', '') is string
        && (!('cuisine' in data) || data.cuisine is list)
        && data.get('avgPrice', 0) is number
        && (!('location' in data) || data.location is string)
        && (!('lat' in data) || data.lat is number)
        && (!('lng' in data) || data.lng is number)
        && (!('country' in data) || data.country is string)
        && (!('pincode' in data) || data.pincode is string)
        && (!('state' in data) || data.state is string)
        && (!('address' in data) || data.address is string)
        && (!('area' in data) || data.area is string)
        && (!('landmark' in data) || data.landmark is string)
        && (!('floor' in data) || data.floor is string)
        && (!('shopNo' in data) || data.shopNo is string)
        && (!('description' in data) || data.description is string)
        && (!('image' in data) || data.image is string)
        && (!('isOpen' in data) || data.isOpen is bool)
        && (!('rating' in data) || data.rating is number)
        && (!('approved' in data) || data.approved is bool)
        && (!('facilities' in data) || data.facilities is list)
        && (!('offers' in data) || data.offers is list)
        && (!('signatureDishes' in data) || data.signatureDishes is list)
        && (!('menuImages' in data) || data.menuImages is list)
        && (!('secondaryImages' in data) || data.secondaryImages is list)
        && (!('openingHours' in data) || data.openingHours is map)
        && (!('dailyTimings' in data) || data.dailyTimings is map)
        && (!('isBookingEnabled' in data) || data.isBookingEnabled is bool)
        && (!('bookingSlots' in data) || data.bookingSlots is list)
        && (!('instantBookingLimit' in data) || data.instantBookingLimit is number)
        && (!('blackoutDates' in data) || data.blackoutDates is list)
        && (!('slotCategories' in data) || data.slotCategories is list)
        && (!('menuCategories' in data) || data.menuCategories is list)
        && (!('city' in data) || data.city is string)
        && (!('contactNumber' in data) || data.contactNumber is string)
        && (!('lastModifiedBy' in data) || data.lastModifiedBy is string)
        && (!('lastModifiedByType' in data) || data.lastModifiedByType is string)
        && (!('aiSummary' in data) || data.aiSummary is string)
        && (!('aiSummaryUpdatedAt' in data) || data.aiSummaryUpdatedAt is timestamp || data.aiSummaryUpdatedAt == null)
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /restaurants/{restaurantId} {
      allow read: if true; 
      
      allow create: if isSignedIn() && isValidId(restaurantId) && (
        isAdmin() || (
          isValidRestaurant(incoming()) && 
          incoming().ownerId == request.auth.uid &&
          incoming().get('approved', false) == false &&
          incoming().get('createdAt', request.time) == request.time
        )
      );

      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(existing().ownerId) && (
          // Strictly control which keys can be modified by the owner
          incoming().diff(existing()).affectedKeys().hasOnly([
            'name', 'description', 'cuisine', 'avgPrice', 'image', 'location', 'city', 'contactNumber',
            'isOpen', 'aiSummary', 'aiSummaryUpdatedAt', 'facilities', 
            'offers', 'signatureDishes', 'menuImages', 'openingHours', 'secondaryImages', 'updatedAt',
            'dailyTimings', 'isBookingEnabled', 'bookingSlots', 'instantBookingLimit', 
            'blackoutDates', 'slotCategories', 'lastModifiedBy', 'lastModifiedByType', 'menuCategories'
          ]) &&
          isValidRestaurant(incoming()) &&
          incoming().ownerId == existing().ownerId &&
          incoming().updatedAt == request.time
        )) ||
        (
          // Allow any signed-in user to update the AI cache fields specifically
          incoming().diff(existing()).affectedKeys().hasOnly(['aiSummary', 'aiSummaryUpdatedAt']) &&
          incoming().aiSummary is string &&
          incoming().aiSummaryUpdatedAt is timestamp
        )
      );
      
      allow delete: if isAdmin();
    }

    // --- Booking Validation ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.restaurantOwnerId == request.auth.uid || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && (
        isAdmin() || (
          incoming().userId == request.auth.uid &&
          incoming().get('status', 'pending') == 'pending' &&
          incoming().get('createdAt', request.time) == request.time
        )
      );
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(existing().restaurantOwnerId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         incoming().status in ['confirmed', 'cancelled'] &&
         incoming().updatedAt == request.time) ||
        (isOwner(existing().userId) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         existing().status == 'pending' &&
         incoming().status == 'cancelled' &&
         incoming().updatedAt == request.time)
      );
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    match /takeaway_orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (exists(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)) && 
         get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerId == request.auth.uid) || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)) && 
         get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerId == request.auth.uid)
      );
      
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && (
          !incoming().diff(existing()).affectedKeys().hasAny(['role', 'createdAt'])
        )) || isAdmin()
      );
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn();
      // Allow any user to update the views array
      allow update: if true; 
      allow delete: if isSignedIn() && (
        isAdmin() || (
          exists(/databases/$(database)/documents/restaurants/$(existing().restaurantId)) && 
          get(/databases/$(database)/documents/restaurants/$(existing().restaurantId)).data.ownerId == request.auth.uid
        )
      );
    }

    // --- City & Cuisine Management ---
    function isValidCity(data) {
      return data.get('name', '') is string && data.get('name', '').size() > 0
        && data.get('lat', 0) is number
        && data.get('lng', 0) is number
        && (!('image' in data) || data.image is string)
        && (!('isPopular' in data) || data.isPopular is bool)
        && (!('isKnown' in data) || data.isKnown is bool);
    }

    function isValidCuisine(data) {
      return data.get('name', '') is string && data.get('name', '').size() > 0
        && (!('image' in data) || data.image is string)
        && (!('description' in data) || data.description is string);
    }

    function isValidSettings(data) {
      return (!('isComingSoon' in data) || data.isComingSoon is bool)
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidSubscription(data) {
      return data.email is string && data.email.size() > 5 
        && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.createdAt is timestamp;
    }

    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCity(incoming());
    }

    match /cuisines/{cuisineId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCuisine(incoming());
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(incoming());
    }

    match /subscriptions/{subscriptionId} {
      allow create: if isValidId(subscriptionId) && isValidSubscription(incoming()) && incoming().createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }
  }
}
